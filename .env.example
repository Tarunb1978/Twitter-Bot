# LLM - OpenAI: https://platform.openai.com/api-keys
# Required when LLM_PROVIDER=openai for all LLM steps; omit or dummy if you use ollama only.
OPENAI_API_KEY=your_key_here

# openai (default) or ollama (local, e.g. llama3.1:8b) for writer, auditor, synthesizer, prioritizer
# LLM_PROVIDER=openai
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:8b
# Optional: OLLAMA_NUM_CTX=8192

# OpenAI 429 / burst smoothing (optional; only when LLM_PROVIDER=openai)
# OPENAI_MIN_CALL_INTERVAL_SEC=0.65
# OPENAI_RATE_LIMIT_MAX_ATTEMPTS=8
# OPENAI_RETRY_BASE_DELAY_SEC=1.25
# OPENAI_RETRY_MAX_DELAY_SEC=90
# OPENAI_SDK_MAX_RETRIES=2

# News - MarketAux (free): https://www.marketaux.com/
MARKETAUX_API_KEY=your_key_here

# News - NewsData.io (free): https://newsdata.io/
NEWSDATA_API_KEY=your_key_here

# Email - Gmail SMTP
# Generate an App Password: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=your_gmail@gmail.com

# smtp (default): send email. terminal: skip SMTP; full premium + standalone printed to stdout.
# EMAIL_DELIVERY=smtp
# EMAIL_DELIVERY=terminal
# Full draft text is printed to the terminal only (not written into logs/). Set false to hide banners.
# PRINT_FINAL_TO_TERMINAL=false
